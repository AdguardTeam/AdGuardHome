.headerCell {
    @media (min-width: 768px) {
        width: 100%;
        min-height: 42px;
        padding: 0 12px;
    }
}

.cell {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 4px 0;

    @media (min-width: 768px) {
        padding: 0;
    }
}

.cellLabel {
    width: 100%;

    @media (min-width: 768px) {
        display: none;
    }
}

.cellValue {
    width: 100%;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    text-align: right;

    @media (min-width: 768px) {
        text-align: left;
        justify-content: initial;
    }
}

.cellActions {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: flex-end;
}

.nameDropdown {
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
}

.nameDropdownInner {
    min-width: 0;
    overflow: hidden;
}

.nameTrigger {
    cursor: pointer;
    display: block;
}

.nameTooltipOverlay {
    max-width: 360px;
}

.nameTooltip {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    padding: 12px 16px;
    background: var(--page-background-additional);
    border-radius: 8px;
    max-width: 100%;
    overflow: hidden;
}

.nameTooltipText {
    font-size: 14px;
    line-height: 1.5;
    color: var(--default-main-text);
    word-break: break-all;
    overflow-wrap: break-word;
    min-width: 0;
}

.copyBtn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    flex-shrink: 0;
    color: var(--default-gray-icons);
    transition: color var(--t2);
    outline: none;

    &:hover {
        color: var(--default-main-text);
    }
}

.copyBtnGreen {
    color: var(--default-product-icon);

    &:hover {
        opacity: 0.8;
    }
}

.copyBtnTopRight {
    position: absolute;
    top: 8px;
    right: 8px;
}

.servicesIcons {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;

    @media (min-width: 768px) {
        flex-wrap: nowrap;
    }
}

.serviceIcon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    color: var(--default-black-icons);
    border-radius: 4px;
    overflow: hidden;

    svg {
        width: 100%;
        height: 100%;
        display: block;
    }
}

.servicesTooltipOverlay {
    max-width: 280px;
}

.servicesTooltip {
    padding: 12px;
    background: var(--page-background-additional);
    border-radius: 8px;
}

.servicesTooltipGrid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

.countLabel {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    border-radius: 200px;
    background-color: transparent;
    border: 1px solid var(--default-item-divider);
    font-size: 13px;
    line-height: 1;
    color: var(--default-main-text);
    cursor: default;
    flex-shrink: 0;
}

.tagsRow {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: nowrap;
    min-width: 0;
    overflow: hidden;
}

.tagsText {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--default-main-text);
}

.tagsTooltipOverlay {
    max-width: 280px;
}

.tagsTooltip {
    position: relative;
    padding: 8px 0;
    padding-right: 36px;
    background: var(--page-background-additional);
    border-radius: 8px;
    max-height: 240px;
    overflow-y: auto;
}

.tagsTooltipItem {
    display: block;
    padding: 8px 16px;
    font-size: 14px;
    line-height: 1.4;
    color: var(--default-main-text);
    white-space: nowrap;
}

.userIcon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
}

.userIconRight {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-left: 8px;
}

.action {
    width: 24px;
    height: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 0;
    outline: 0;
    cursor: pointer;
    background: none;
    color: var(--default-gray-icons);

    &:disabled {
        cursor: default;
        color: var(--disabled-secondary-button-stroke);
    }

    &_danger {
        color: var(--red);
    }
}

.table {
    @media (min-width: 768px) {
        grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr 1fr 80px;
    }
}

.ids {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;

    @media (min-width: 768px) {
        align-items: flex-start;
    }
}

.idsRow {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: nowrap;
    min-width: 0;
    overflow: hidden;
}

.idsText {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--default-main-text);
    min-width: 0;
}

.idsTooltipOverlay {
    max-width: 360px;
}

.idsTooltip {
    position: relative;
    padding: 8px 0;
    padding-right: 36px;
    background: var(--page-background-additional);
    border-radius: 8px;
    max-height: 240px;
    overflow-y: auto;
}

.idsTooltipItem {
    display: block;
    padding: 8px 16px;
    font-size: 14px;
    line-height: 1.4;
    color: var(--default-main-text);
    word-break: break-all;
    white-space: normal;
}
