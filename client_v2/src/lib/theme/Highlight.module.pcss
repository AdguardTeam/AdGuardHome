.textOutput {
    position: absolute;
    top: 1px;
    left: 1px;
    width: 100%;
    height: 100%;
    padding: 16px;
    box-sizing: border-box;
    pointer-events: none;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-y: auto;
    font-size: 16px;
    line-height: 1.3;
    font-family: inherit;
}

.textGray {
    color: var(--disabled-main-text);
}

.textTransparent {
    color: transparent;
}
