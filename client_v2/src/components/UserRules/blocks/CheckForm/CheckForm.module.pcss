.formFields {
    display: flex;
    flex-direction: column;
}

.formGroup {
    display: flex;
    flex-direction: column;
    padding: 8px 0;
}

.selectField {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.selectLabel {
    margin-bottom: 4px;
    color: var(--default-description-text);
}

.checkActions {
    display: flex;
    padding: 8px 0;
}

.checkSubmitButton {
    width: 100%;
    min-width: 0;
    max-width: none;
}
