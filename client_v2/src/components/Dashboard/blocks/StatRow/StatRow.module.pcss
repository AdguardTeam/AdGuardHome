.statRow {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0 24px;
    padding: 16px;
    min-height: 40px;
    transition: background-color var(--t2);

    @media (min-width: 768px) {
        padding: 8px 16px;
        flex-wrap: nowrap;
    }

    &.dnsQueries {
        & .tableRowIcon {
            color: var(--default-gray-icons);
        }
    }

    &.adsBlocked {
        & .queryCount,
        & .tableRowIcon {
            color: var(--default-error-icon);
        }

        & .queryBarFill {
            background: var(--default-error-icon);
        }
    }

    &.threatsBlocked {
        & .queryCount,
        & .tableRowIcon {
            color: var(--default-attention-icon-stroke);
        }

        & .queryBarFill {
            background: var(--default-attention-icon-stroke);
        }
    }

    &.adultWebsitesBlocked {
        & .queryCount,
        & .tableRowIcon {
            color: var(--default-product-secondary-icon-stroke);
        }

        & .queryBarFill {
            background: var(--default-product-secondary-icon-stroke);
        }
    }

    &.safeSearchUsed {
        & .queryCount,
        & .tableRowIcon {
            color: var(--default-product-icon);
        }

        & .queryBarFill {
            background: var(--default-product-icon);
        }
    }
}

.statRowDropdown {
    display: flex;
    align-items: center;
    flex-direction: column;
}

.statRowLeft {
    display: flex;
    align-items: center;
    gap: 12px;
}

.statRowIcon {
    width: 20px;
    height: 20px;
    color: var(--default-description-text);
}

.statRowLabel {
    font-size: 14px;
    color: var(--default-main-text);
}

.statRowValue {
    display: flex;
    align-items: center;
    gap: 16px;

    & .queryBar {
        min-width: 141px;
    }
}

.statRowPercent {
    font-size: 12px;
    color: var(--default-description-text);
    margin-left: 4px;
}

.tableRowIcon {
    width: 24px;
    height: 24px;
    stroke: var(--default-gray-icons);
    color: var(--default-gray-icons);
}

.queryCount {
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
}

.dropdownWrapper {
    flex-shrink: 0;
}

.queryPercent {
    font-size: 12px;
    color: var(--default-description-text);
}

.queryBar {
    display: none;
    width: 100%;
    min-width: 102px;
    height: 3px;
    background: var(--default-item-divider);
    border-radius: 2px;

    @media (min-width: 768px) {
        display: block;
    }
}

.queryBarMobile {
    display: block;
    margin: 16px 0 0;

    @media (min-width: 768px) {
        display: none;
    }
}

.queryBarFill {
    height: 100%;
    background: var(--default-tertiary-stat);
}

.queryTooltip {
    font-size: var(--fs-text-t3);
    line-height: var(--lh-t3-normal);
    padding: 8px 12px;
    white-space: nowrap;
}

.queryTooltipOverlay {
    pointer-events: none;
}

.statTooltip {
    max-width: 280px;
    padding: 16px;
}
