.textareaWrapper {
    display: flex;
    flex-direction: column;
}

.textarea {
    font-size: 16px;
    line-height: 1.3;
    width: 100%;
    max-width: 100%;
    padding: 16px;
    border: 1px solid var(--default-item-divider);
    outline: none;
    color: var(--default-main-text);
    background-color: var(--default-page-background);
    border-radius: 8px;
    transition:
        border var(--t2),
        background-color var(--t2);
    resize: none;

    &:focus {
        border-color: var(--pressed-link);
    }

    &::placeholder {
        color: var(--default-placeholder);
    }

    &.error {
        border-color: var(--default-error-icon);
    }

    &:disabled {
        background-color: var(--pressed-page-background);
        color: var(--default-description-text);
        cursor: default;

        &:-webkit-autofill,
        &:-webkit-autofill:hover,
        &:-webkit-autofill:focus {
            box-shadow: 0 0 0 100px var(--pressed-page-background) inset;
        }
    }

    &.medium {
        min-height: 120px;
    }

    &.large {
        min-height: 200px;
    }
}

.label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
    font-size: 14px;
    line-height: 24px;
    color: var(--default-description-text);
}

.scrollArea {
    overflow: auto;
    border: 1px solid var(--default-item-divider);
    border-radius: 8px;
    background-color: var(--default-page-background);
    transition:
        border var(--t2),
        background-color var(--t2);
    scrollbar-width: none;

    &::-webkit-scrollbar {
        display: none;
    }

    &:focus-within {
        border-color: var(--pressed-link);
    }

    &.error {
        border-color: var(--default-error-icon);
    }

    &.medium {
        min-height: 120px;
    }

    &.large {
        min-height: 200px;
    }
}

.contentWrapper {
    position: relative;
}

.overlay {
    white-space: pre-wrap;
    word-wrap: break-word;
    padding: 16px;
    box-sizing: border-box;
    font-size: 16px;
    line-height: 1.3;
    max-width: 100%;
    pointer-events: none;
}

.commentLine {
    color: var(--default-additional-link);
}

.overlayNonComment {
    color: var(--default-main-text);
}

.transparentText {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    color: transparent;
    caret-color: var(--default-main-text);
    background: transparent;
    border: none;
    padding: 16px;
    box-sizing: border-box;
    font-size: 16px;
    line-height: 1.3;
    resize: none !important;
    outline: none;
    white-space: pre-wrap;
    word-wrap: break-word;

    &::placeholder {
        color: var(--default-placeholder);
    }

    &:disabled {
        color: transparent;
        caret-color: var(--default-description-text);
    }
}

.errorMessage {
    margin-top: 8px;
    font-size: 14px;
    color: var(--default-error-icon);
}
